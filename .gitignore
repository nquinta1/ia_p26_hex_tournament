# ══════════════════════════════════════════════════════════
# .gitignore — Hex Tournament Framework
# ══════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.so
!strategies/*.so
*.egg-info/
*.egg
dist/
build/
*.whl

# ── Virtual environments ──────────────────────────────────
.venv/
venv/
env/
.conda/
conda-env/

# ── IDE / Editors ─────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.cursorignore
.cursorindexingignore
.project
.settings/

# ── Testing ───────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Type checkers / linters ───────────────────────────────
.mypy_cache/
.ruff_cache/
.pytype/

# ── Environment / secrets ─────────────────────────────────
.env
.envrc
*.pem
*.key
credentials*

# ── Claude Code ───────────────────────────────────────────
CLAUDE.md
.claude/

# ── Codex ─────────────────────────────────────────────────
.codex/

# ── Tournament results (generated, never commit) ─────────
results/
**/results/

# ── Generated artifacts (plots, logs, etc) ────────────────
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.pdf
*.log
*.out

# ── Large / binary files (students may accidentally add) ──
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
*.pkl
*.pickle
*.h5
*.hdf5
*.npy
*.npz
*.parquet
*.feather
*.model
*.pt
*.pth
*.onnx
*.pb
*.sqlite
*.db
*.csv
!requirements.txt

# ── Jupyter notebooks outputs (large, merge conflicts) ────
.ipynb_checkpoints/
*.ipynb

# ── OS files ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Docker ────────────────────────────────────────────────
docker-compose.override.yml
docker-compose.build.yml

# ── Strategy source (professor only, compiled .so shipped) ─
strategies/_src/
tools/

# ── OpenSpec ──────────────────────────────────────────────
openspec/
